{
  "storage_root": "./data/fin_raw",
  "metadata_db": "./data/metadata.sqlite3",
  "sec": {
    "user_agent": "RawFinancialDataLake/0.1 contact@example.com",
    "sample_companies": [
      {
        "ticker": "AAPL",
        "cik": "320193",
        "name": "Apple Inc."
      },
      {
        "ticker": "MSFT",
        "cik": "789019",
        "name": "Microsoft Corporation"
      },
      {
        "ticker": "TSLA",
        "cik": "1318605",
        "name": "Tesla, Inc."
      }
    ],
    "bulk_datasets": [
      {
        "name": "companyfacts",
        "source_id": "sec_companyfacts",
        "url": "https://www.sec.gov/Archives/edgar/daily-index/xbrl/companyfacts.zip",
        "object_type": "zip",
        "relative_path": "sec/companyfacts/snapshot_date={snapshot_date}/companyfacts.zip"
      },
      {
        "name": "submissions",
        "source_id": "sec_submissions",
        "url": "https://www.sec.gov/Archives/edgar/daily-index/xbrl/submissions.zip",
        "object_type": "zip",
        "relative_path": "sec/submissions/snapshot_date={snapshot_date}/submissions.zip"
      }
    ],
    "filing_companies": [
      {
        "ticker": "AAPL",
        "cik": "320193",
        "name": "Apple Inc."
      },
      {
        "ticker": "MSFT",
        "cik": "789019",
        "name": "Microsoft Corporation"
      },
      {
        "ticker": "TSLA",
        "cik": "1318605",
        "name": "Tesla, Inc."
      }
    ],
    "filing_forms": [
      "10-K",
      "10-Q",
      "8-K"
    ],
    "filing_limit_per_company": 3
  },
  "fred": {
    "base_url": "https://api.stlouisfed.org/fred",
    "series_ids": [
      "GDP",
      "CPIAUCSL",
      "PPIACO",
      "UNRATE",
      "FEDFUNDS",
      "DGS10",
      "INDPRO",
      "RSAFS",
      "DEXUSEU",
      "DEXCHUS"
    ],
    "include_metadata": true,
    "include_release": true,
    "include_vintages": true
  },
  "worldbank": {
    "base_url": "https://api.worldbank.org/v2",
    "countries": [
      "USA",
      "CHN",
      "JPN",
      "DEU",
      "GBR"
    ],
    "indicators": [
      "NY.GDP.MKTP.CD",
      "NY.GDP.MKTP.KD.ZG",
      "SP.POP.TOTL",
      "FP.CPI.TOTL.ZG",
      "NE.EXP.GNFS.CD",
      "NE.IMP.GNFS.CD",
      "BX.KLT.DINV.CD.WD",
      "BN.CAB.XOKA.CD"
    ],
    "date_range": "1990:2025",
    "include_country_metadata": true,
    "include_indicator_metadata": true
  },
  "metadata_backend": {
    "type": "sqlite",
    "postgres_schema": "./sql/postgres_schema.sql"
  },
  "export": {
    "jsonl_dir": "./data/exports/jsonl",
    "parquet_dir": "./data/exports/parquet"
  },
  "imf": {
    "targets": [],
    "note": "Add SDMX 2.1/3.0 target URLs here. Connector stores raw JSON/XML responses."
  },
  "cninfo": {
    "announcements": [],
    "note": "Add direct CNInfo PDF announcement URLs here. Connector stores raw PDFs and metadata."
  },
  "storage_policy": {
    "backend": "local_filesystem",
    "storage_root": "./data/fin_raw",
    "storage_budget_bytes": 322122547200,
    "minimum_free_bytes": 536870912000,
    "migration_targets": [
      "minio",
      "s3",
      "nas"
    ]
  },
  "quality_gates": {
    "raise_on_failure": true,
    "max_failed_objects": 0,
    "max_warning_objects": 5,
    "min_raw_objects_by_source": {},
    "min_raw_records_by_type": {}
  },
  "fact_quality_gates": {
    "raise_on_failure": true,
    "max_missing_entity_count": 0,
    "max_missing_metric_count": 0,
    "max_missing_period_end_count": 0,
    "max_missing_source_count": 0,
    "max_null_value_count": 0,
    "max_document_fact_count": 0,
    "max_rejected_ratio": 0.001,
    "max_conflict_ratio": 0.01,
    "min_graph_ready_count": 1,
    "min_graph_ready_ratio": 0.9,
    "min_cross_verified_ratio": 0.0,
    "max_single_source_ratio": 1.0,
    "critical_metrics": [
      "revenue",
      "total_assets",
      "net_income"
    ],
    "min_years_per_company_critical_metric": 0
  },
  "kg": {
    "retention": {
      "hot_build_count": 2,
      "archive_dir": "./data/kg_archive",
      "archive_format": "parquet",
      "compression": "zstd"
    },
    "query": {
      "default_limit": 100,
      "max_limit": 1000
    },
    "time_hierarchy": {
      "enabled": true
    },
    "derived_policy": {
      "multi_year_windows": [
        5,
        10
      ],
      "long_window_return_years": [
        1,
        5,
        10
      ],
      "rolling_observations": {
        "daily": 252,
        "weekly": 52,
        "monthly": 12,
        "quarterly": 4,
        "annual": 5
      }
    }
  },
  "qa": {
    "quotas": {
      "single_fact_financial": 20000,
      "single_fact_macro": 10000,
      "single_fact_fred": 5000
    },
    "derived_quotas": {
      "difference": 9000,
      "yoy_growth": 9000,
      "qoq_growth": 7000,
      "ratio": 5000,
      "share": 3000,
      "multi_year_argmax": 3000,
      "multi_year_argmin": 3000,
      "industry_ranking": 1600,
      "industry_argmax": 1200,
      "industry_argmin": 1200,
      "ranking": 150,
      "argmax": 150,
      "argmin": 150,
      "rolling_max": 50,
      "rolling_min": 50,
      "macro_time_series_argmax": 33,
      "macro_time_series_argmin": 33,
      "time_series_argmax": 17,
      "time_series_argmin": 17,
      "multi_condition_screening": 100,
      "long_window_return": 10
    },
    "language": "en",
    "paraphrase": {
      "enabled": false,
      "max_per_group": 0
    },
    "split_policy": "semantic_group_then_entity_time_task"
  }
}
