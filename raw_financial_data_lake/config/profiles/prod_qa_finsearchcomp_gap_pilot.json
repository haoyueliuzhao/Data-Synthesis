{
  "metadata_backend": {
    "type": "postgres",
    "dsn_env": "DATABASE_URL",
    "postgres_schema": "./sql/postgres_schema.sql",
    "dsn": "postgresql:///finraw"
  },
  "qa": {
    "language": "zh",
    "benchmark_alignment": {
      "greater_china_source_ids": ["worldbank_indicators"],
      "greater_china_entity_ids": [
        "CHN_COUNTRY",
        "HKG_COUNTRY",
        "MAC_COUNTRY"
      ],
      "greater_china_derived_quotas": {
        "multi_year_argmax": 15,
        "multi_year_argmin": 15
      }
    },
    "quotas": {
      "single_fact_financial": 0,
      "single_fact_fred": 0,
      "single_fact_worldbank": 0,
      "single_fact_imf": 0,
      "single_fact_greater_china": 120
    },
    "derived_quotas": {
      "difference": 0,
      "yoy_growth": 0,
      "qoq_growth": 0,
      "ratio": 0,
      "share": 0,
      "multi_year_argmax": 0,
      "multi_year_argmin": 0,
      "industry_ranking": 0,
      "industry_argmax": 0,
      "industry_argmin": 0,
      "ranking": 0,
      "argmax": 0,
      "argmin": 0,
      "rolling_max": 0,
      "rolling_min": 0,
      "macro_time_series_argmax": 0,
      "macro_time_series_argmin": 0,
      "time_series_argmax": 0,
      "time_series_argmin": 0,
      "multi_condition_screening": 0,
      "long_window_return": 0
    },
    "graph_patterns": {
      "enabled": true,
      "quotas": {
        "pairwise_entity_metric_comparison": 0,
        "entity_cross_metric_comparison": 0,
        "entity_metric_temporal_average": 50,
        "temporal_argmax_then_metric_lookup": 60,
        "industry_growth_filter_then_margin_rank": 40,
        "industry_revenue_rank_then_assets_lookup": 40,
        "industry_multi_factor_screening": 40
      }
    },
    "pattern_mining": {
      "enabled": false,
      "auto_run": false,
      "compiled_graph_scan_rows": 50,
      "compiled_graph_evaluation_rows": 50,
      "compiled_max_per_stratum": 2
    },
    "question_generation": {
      "mode": "controlled_template",
      "strategy": "sentence_plan",
      "variants": 3,
      "language": "zh",
      "benchmark_alignment": {
        "enabled": true,
        "explicit_unit": true,
        "explicit_precision": true,
        "explicit_output_format": true,
        "decimal_places": 2
      }
    },
    "quality_gate": {
      "minimum_overall_pass_rate": 1.0,
      "critical_tasks": {
        "single_fact": 100,
        "yoy_growth": 0,
        "qoq_growth": 0,
        "ratio": 0
      },
      "max_critical_check_failures": 0,
      "minimum_graph_pattern_samples": {
        "pairwise_entity_metric_comparison": 0,
        "entity_cross_metric_comparison": 0,
        "entity_metric_temporal_average": 40,
        "temporal_argmax_then_metric_lookup": 50,
        "industry_growth_filter_then_margin_rank": 30,
        "industry_revenue_rank_then_assets_lookup": 30,
        "industry_multi_factor_screening": 30
      },
      "minimum_graph_pattern_eligibility_rate": 0.95,
      "minimum_graph_feature_coverage": 0.60,
      "minimum_unique_operation_sequences": 5,
      "minimum_difficulty_samples": {
        "easy": 0,
        "medium": 0,
        "hard": 0,
        "expert": 0,
        "research": 0
      },
      "minimum_difficulty_ratios": {
        "easy": 0,
        "medium": 0,
        "hard": 0,
        "expert": 0,
        "research": 0
      }
    }
  }
}
